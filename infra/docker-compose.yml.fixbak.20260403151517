services:
  food-frontend:
    image: nginx:alpine
    container_name: food-frontend
    restart: unless-stopped
    volumes:
      - ../frontend:/usr/share/nginx/html:ro
    networks:
      - traefik_default
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.food.rule=Host(`food.helixscribe.cloud`)"
      - "traefik.http.routers.food.entrypoints=websecure"
      - "traefik.http.routers.food.tls=true"
      - "traefik.http.routers.food.tls.certresolver=letsencrypt"
      - "traefik.http.routers.food.service=food-service"
      - "traefik.http.services.food-service.loadbalancer.server.port=80"

  food-api:
    build: ./backend
    ports:
      - "8001:8000"
    ports:
      - "8001:8000"
    ports:
      - "8001:8000"
      context: ../backend
    container_name: food-api
    restart: unless-stopped
    extra_hosts:
      - "postgresql:host-gateway"
    environment:
      DATABASE_URL: "postgresql://helixscribe:Tennisandy23!@postgresql:5432/helixscribe"
    networks:
      - traefik_default
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.food-api.rule=Host(`api.food.helixscribe.cloud`)"
      - "traefik.http.routers.food-api.entrypoints=websecure"
      - "traefik.http.routers.food-api.tls=true"
      - "traefik.http.routers.food-api.tls.certresolver=letsencrypt"
      - "traefik.http.routers.food-api.service=food-api-service"
      - "traefik.http.services.food-api-service.loadbalancer.server.port=8000"

networks:
  traefik_default:
    external: true
